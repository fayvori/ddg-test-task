services:
  prometheus:
    image: {{ prometheus_image }}:{{ prometheus_version }}
    container_name: prometheus
    restart: unless-stopped
    volumes:
      - ./prometheus/prometheus.yml:{{ prometheus_config_path }}/prometheus.yml:ro
      - prometheus_data:{{ prometheus_storage_path }}
    command:
      - '--config.file={{ prometheus_config_path }}/prometheus.yml'
      - '--storage.tsdb.path={{ prometheus_storage_path }}'
      - '--storage.tsdb.retention.time={{ prometheus_retention_time }}'
      - '--web.enable-lifecycle'
      - '--web.enable-admin-api'
    ports:
      - "{{ prometheus_port }}:9090"
    networks:
      - {{ docker_compose_monitoring_network }}

  grafana:
    image: {{ grafana_image }}:{{ grafana_version }}
    container_name: grafana
    restart: unless-stopped
    environment:
      - GF_SECURITY_ADMIN_USER={{ grafana_admin_user }}
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
      - GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-simple-json-datasource
      - GF_SERVER_ROOT_URL=http://localhost:{{ grafana_port }}
      - GF_AUTH_ANONYMOUS_ENABLED=true
      - GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
    volumes:
      - grafana_data:/var/lib/grafana
      - ./grafana/provisioning:{{ grafana_provisioning_path }}:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards
    ports:
      - "{{ grafana_port }}:3000"
    networks:
      - {{ docker_compose_monitoring_network }}
    depends_on:
      - prometheus

networks:
  {{ docker_compose_monitoring_network }}:
    driver: bridge

volumes:
  prometheus_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ prometheus_storage_path }}
  grafana_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ grafana_storage_path }}
